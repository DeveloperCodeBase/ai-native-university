# ==============================================================
# AI-Native Online University Platform — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ==============================================================

# --- General ---
NODE_ENV=development
EXTERNAL_PORT=3010
APP_BASE_URL=http://193.163.201.141:3010

# --- Database (PostgreSQL 16) ---
POSTGRES_USER=ainu
POSTGRES_PASSWORD=ainu_secret
POSTGRES_DB=ainu_db
DATABASE_URL=postgresql://ainu:ainu_secret@localhost:5432/ainu_db?schema=public

# --- Redis ---
REDIS_URL=redis://:ainu_redis_secret@localhost:6379
REDIS_PASSWORD=ainu_redis_secret

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=ainu_minio
MINIO_SECRET_KEY=ainu_minio_secret
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_UPLOADS=uploads

# --- Authentication ---
JWT_SECRET=change-me-jwt-secret-must-be-32-chars-or-more
JWT_EXPIRATION_SECONDS=86400
JWT_REFRESH_EXPIRATION_SECONDS=604800

# --- AI Gateway ---
AI_MODE=mock
AI_GATEWAY_URL=http://localhost:8000
AI_GATEWAY_API_KEY=change-me-gateway-key
AI_SERVICES_BASE_URL=https://future-gpu-server.example.com
AI_SERVICES_API_KEY=change-me
AI_TIMEOUT_SECONDS=120

# --- OpenRouter (mandatory AI provider per AGENT_RUNBOOK.md) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# --- CORS ---
CORS_ORIGIN=*

# --- Frontend Public ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_AI_GATEWAY_URL=/ai

# --- Live Class Provider (future) ---
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=

# --- VPS Deployment ---
# VPS_HOST=your-server-ip
# VPS_USER=root
# VPS_PROJECT_DIR=/opt/ai-native-university
